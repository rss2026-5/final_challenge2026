<launch>
    <!-- Part A: The Great Snail Race (real hardware) -->

    <node pkg="final_challenge" exec="lane_detector" name="lane_detector" output="screen">
        <param from="$(find-pkg-share final_challenge)/config/real/race_config.yaml"/>
    </node>

    <node pkg="final_challenge" exec="homography_transformer" name="homography_transformer" output="screen"/>

    <node pkg="final_challenge" exec="lane_follower" name="lane_follower" output="screen">
        <param from="$(find-pkg-share final_challenge)/config/real/race_config.yaml"/>
    </node>

    <node pkg="final_challenge" exec="race_safety_controller" name="race_safety_controller" output="screen">
        <param from="$(find-pkg-share final_challenge)/config/real/race_config.yaml"/>
    </node>
</launch>
